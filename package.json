{
  "name": "documentacion_cucumber",
  "version": "1.0.0",
  "description": "Cypress and Cucumber project",
  "main": "index.js",
  "license": "MIT",
  "scripts": {
    "open": "npx cypress open --config-file cypress.config.js",
    "open:local": "npx cypress open --config-file cypress.config.js",
    "open:des": "npx cypress open --config-file cypress.config.js",
    "generate:report": "./node_modules/.bin/generate-mochawesome-report --saveJson --jsonDir results/mochawesome/json -o results/mochawesome/report"
  },
  "dependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^24.0.1",
    "@cypress/webpack-preprocessor": "^6.0.1",
    "cucumber-json-merge": "^0.0.8",
    "cypress-file-upload": "^5.0.8",
    "cypress-image-diff-js": "^2.1.4",
    "cypress-mochawesome-reporter": "^3.8.2",
    "cypress-multi-reporters": "^1.6.4",
    "mocha": "^10.4.0",
    "mocha-junit-reporter": "^2.2.1",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0"
  },
  "cypress-cucumber-preprocessor": {
    "cucumberJson": {
      "generate": true,
      "outputFolder": "results/cucumber/json",
      "filePrefix": "",
      "fileSuffix": ".cucumber"
    }
  },
  "devDependencies": {
    "cypress": "^15.12.0"
  }
}
